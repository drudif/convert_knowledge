# Chave Gemini — usada na ingestão (embeddings dos chunks) e no /search (embedding da query).
GEMINI_API_KEY=

# Porta do serviço HTTP.
PORT=8787

# Lista de chaves aceitas pelo serviço (separadas por vírgula, sem espaços).
# Cada app consumidor (toads, bb_cnvrt_v2, vibe-hub) armazena UMA dessas chaves na sua
# própria var KNOWLEDGE_API_KEY (singular) e a envia no header x-api-key em cada request.
# ATENÇÃO: se ficar vazia em produção, a autenticação fica DESABILITADA — qualquer client
# consegue consultar o índice. Deixar vazio só é aceitável em dev local.
KNOWLEDGE_API_KEYS=

# Chave separada para rotas administrativas: POST /reindex, POST /documents (upload),
# PATCH /documents/:id/disable e PATCH /documents/:id/enable.
# Deve ser diferente e mais restrita do que as chaves em KNOWLEDGE_API_KEYS.
# Se vazia em produção, essas rotas ficam desprotegidas.
ADMIN_API_KEY=

# CORS: origens autorizadas (separadas por vírgula). Ex.: https://bb.seudominio.com,https://hub.seudominio.com
# Use "*" para liberar geral (apenas dev). Adicionar um projeto novo = adicionar a origem aqui.
ALLOWED_ORIGINS=*
