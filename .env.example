# Chave Gemini — usada na ingestão (embeddings dos chunks) e no /search (embedding da query).
GEMINI_API_KEY=

# Porta do serviço HTTP.
PORT=8787

# Auth: chaves de API autorizadas a consumir o serviço (separadas por vírgula).
# Cada projeto/cliente recebe uma. Deixe vazio para desabilitar a checagem (apenas dev local).
KNOWLEDGE_API_KEYS=

# Chave de administrador para rotas protegidas (POST /reindex).
ADMIN_API_KEY=

# CORS: origens autorizadas (separadas por vírgula). Ex.: https://bb.seudominio.com,https://hub.seudominio.com
# Use "*" para liberar geral (apenas dev). Adicionar um projeto novo = adicionar a origem aqui.
ALLOWED_ORIGINS=*
